@model Ejercicio_Generación_Etiquetas.ViewModels.EtiquetaViewModel

@{
    ViewData["Title"] = "Eliminar solicitud";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Eliminar solicitud</h1>
        <p class="text-muted mb-0">Confirma si deseas eliminar esta solicitud de etiquetas.</p>
    </div>

    <a asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
</div>

<div class="card border-danger">
    <div class="card-header bg-danger text-white">Confirmación requerida</div>

    <div class="card-body">
        <p>Estás a punto de eliminar la siguiente solicitud:</p>

        <dl class="row mb-4">
            <dt class="col-sm-3">Número de etiqueta</dt>
            <dd class="col-sm-9">@Model.NumeroEtiqueta</dd>

            <dt class="col-sm-3">Orden</dt>
            <dd class="col-sm-9">@Model.Orden</dd>

            <dt class="col-sm-3">Modelo</dt>
            <dd class="col-sm-9">@Model.Modelo</dd>

            <dt class="col-sm-3">Cantidad solicitada</dt>
            <dd class="col-sm-9">@Model.CantidadSolicitada</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                <span class="badge bg-@Model.ClaseBootstrapEstado">@Model.Estado</span>
            </dd>
        </dl>

        @if (Model.Estado == Ejercicio_Generación_Etiquetas.Models.EstadoEtiqueta.Impresa)
        {
            <div class="alert alert-warning mb-0">
                Esta etiqueta ya fue impresa y no puede eliminarse.
            </div>
        }
        else
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">Sí, eliminar solicitud</button>
                <a asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
            </form>
        }
    </div>
</div>
