@model IEnumerable<Ejercicio_Generación_Etiquetas.ViewModels.EtiquetaViewModel>

@{
    ViewData["Title"] = "Etiquetas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Lista de Etiquetas</h1>
    <a asp-action="Create" class="btn btn-success">Nueva solicitud</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="termino" class="form-label">Buscar</label>
                <input type="text"
                       id="termino"
                       name="termino"
                       class="form-control"
                       value="@ViewBag.Termino"
                       placeholder="Orden, modelo o usuario" />
            </div>
            <div class="col-md-2">
                <label for="estado" class="form-label">Estado</label>
                <select id="estado" name="estado" class="form-select" asp-items="ViewBag.Estados">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="prioridad" class="form-label">Prioridad</label>
                <select id="prioridad" name="prioridad" class="form-select" asp-items="ViewBag.Prioridades">
                    <option value="">Todas</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="impresora" class="form-label">Impresora</label>
                <select id="impresora" name="impresora" class="form-select" asp-items="ViewBag.Impresoras">
                    <option value="">Todas</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>Número</th>
                    <th>Orden</th>
                    <th>Modelo</th>
                    <th>Usuario</th>
                    <th>Impresora</th>
                    <th>Estado</th>
                    <th>Prioridad</th>
                    <th>Avance</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No se encontraron etiquetas.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var etiqueta in Model)
                    {
                        <tr>
                            <td>@etiqueta.NumeroEtiqueta</td>
                            <td>@etiqueta.Orden</td>
                            <td>@etiqueta.Modelo</td>
                            <td>@etiqueta.Usuario</td>
                            <td>@etiqueta.Impresora</td>
                            <td>
                                <span class="badge bg-@(etiqueta.ClaseBootstrapEstado)">@etiqueta.Estado</span>
                            </td>
                            <td>@etiqueta.Prioridad</td>
                            <td>@(etiqueta.PorcentajeAvance.ToString("F1"))%</td>
                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@etiqueta.Id" class="btn btn-sm btn-outline-primary icon-action" aria-label="Ver detalle" title="Ver detalle">
                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@etiqueta.Id" class="btn btn-sm btn-outline-secondary icon-action" aria-label="Editar" title="Editar">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@etiqueta.Id" class="btn btn-sm btn-outline-danger icon-action" aria-label="Eliminar" title="Eliminar">
                                    <i class="bi bi-trash3" aria-hidden="true"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Dashboard" class="btn btn-outline-dark">Volver al Dashboard</a>
</div>
