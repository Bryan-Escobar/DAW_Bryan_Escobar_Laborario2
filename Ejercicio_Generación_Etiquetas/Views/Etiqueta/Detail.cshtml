@model Ejercicio_Generación_Etiquetas.ViewModels.EtiquetaViewModel

@{
    ViewData["Title"] = "Detalle de etiqueta";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Detalle de etiqueta</h1>
        <p class="text-muted mb-0">@Model.NumeroEtiqueta</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Información de la solicitud</span>
        <span class="badge bg-@Model.ClaseBootstrapEstado">@Model.Estado</span>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4"><strong>Orden:</strong><div>@Model.Orden</div></div>
            <div class="col-md-4"><strong>Modelo:</strong><div>@Model.Modelo</div></div>
            <div class="col-md-4"><strong>Color / talla:</strong><div>@Model.Color / @Model.Talla</div></div>
            <div class="col-md-4"><strong>Usuario:</strong><div>@Model.Usuario</div></div>
            <div class="col-md-4"><strong>Impresora:</strong><div>@Model.Impresora</div></div>
            <div class="col-md-4"><strong>Prioridad:</strong><div>@Model.Prioridad</div></div>
            <div class="col-md-4"><strong>Fecha de solicitud:</strong><div>@Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</div></div>
            <div class="col-md-4"><strong>Tiempo transcurrido:</strong><div>@Model.TiempoTranscurrido</div></div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Progreso de impresión</div>

    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4"><strong>Solicitadas:</strong> @Model.CantidadSolicitada</div>
            <div class="col-md-4"><strong>Generadas:</strong> @Model.CantidadGenerada</div>
            <div class="col-md-4"><strong>Pendientes:</strong> @Model.CantidadPendiente</div>
        </div>

        <div class="progress" style="height: 28px;">
            <div class="progress-bar bg-@Model.ClaseBootstrapEstado"
                 role="progressbar"
                 style="width: @Model.PorcentajeAvance.ToString("F0")%;"
                 aria-valuenow="@Model.PorcentajeAvance.ToString("F0")"
                 aria-valuemin="0"
                 aria-valuemax="100">
                @Model.PorcentajeAvance.ToString("F1")%
            </div>
        </div>
    </div>
</div>

@if (Model.Estado != Ejercicio_Generación_Etiquetas.Models.EstadoEtiqueta.Impresa &&
     Model.Estado != Ejercicio_Generación_Etiquetas.Models.EstadoEtiqueta.Cancelada)
{
    <div class="card plant-operations mb-4">
        <div class="card-header d-flex align-items-center gap-2">
            <i class="bi bi-gear-wide-connected text-primary"></i>
            Operaciones de planta
        </div>

        <div class="card-body p-3">
            <div class="row g-3 align-items-stretch">
                <div class="col-lg-5">
                    <div class="operation-panel h-100">
                        <div class="d-flex gap-2 mb-3">
                            <span class="operation-icon text-success"><i class="bi bi-printer"></i></span>
                            <div><h6 class="mb-0">Generar etiquetas</h6><small class="text-muted">Pendientes: @Model.CantidadPendiente</small></div>
                        </div>
                        <form asp-action="Generar" method="post" class="d-flex gap-2 align-items-end">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="flex-grow-1">
                                <label for="cantidad" class="form-label small mb-1">Cantidad a generar</label>
                                <input id="cantidad" name="cantidad" type="number" min="1" max="@Model.CantidadPendiente" class="form-control" required />
                            </div>
                            <button type="submit" class="btn btn-success"><i class="bi bi-play-fill me-1"></i>Generar</button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="operation-panel h-100">
                        <div class="d-flex gap-2 mb-3">
                            <span class="operation-icon text-primary"><i class="bi bi-arrow-repeat"></i></span>
                            <div><h6 class="mb-0">Cambiar estado</h6><small class="text-muted">Actualiza el seguimiento</small></div>
                        </div>
                        <form asp-action="CambiarEstado" method="post" class="d-flex gap-2 align-items-end">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="flex-grow-1">
                                <label for="nuevoEstado" class="form-label small mb-1">Nuevo estado</label>
                                <select id="nuevoEstado" name="nuevoEstado" class="form-select">
                                    <option value="Pendiente">Pendiente</option>
                                    <option value="Procesando">Procesando</option>
                                    <option value="Error">Error</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary" aria-label="Actualizar estado" title="Actualizar estado"><i class="bi bi-check-lg"></i></button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-3">
                    <div class="operation-panel operation-cancel h-100 d-flex flex-column">
                        <div class="d-flex gap-2 mb-3">
                            <span class="operation-icon text-danger"><i class="bi bi-x-circle"></i></span>
                            <div><h6 class="mb-0">Cancelar</h6><small class="text-muted">Detiene la solicitud</small></div>
                        </div>
                        <form asp-action="Cancelar" method="post" class="mt-auto">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-x-lg me-1"></i>Cancelar</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Eliminar</a>
</div>
